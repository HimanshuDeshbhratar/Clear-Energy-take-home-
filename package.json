{
  "name": "clear-energy-takehome",
  "version": "1.0.0",
  "private": true,
  "description": "Clear Energy 3-app take-home: Customer, Driver, and Admin Mobile apps sharing types, an API client, and an OrderCard component.",
  "scripts": {
    "mock-api": "json-server mock-api.json --port 4000",
    "test": "pnpm --filter @clear-energy/shared run test",
    "typecheck": "pnpm -r run typecheck",
